# Copy to .env.staging (gitignored) or export in the shell before:
#   docker compose -f docker-compose.staging.yml --env-file .env.staging up --build
#
# NEVER commit real keys. Staging MUST leave AEIOS_AUTH_DISABLED unset.

AEIOS_ENV=staging
AEIOS_API_PORT=8080
DATABASE_URL=sqlite:///./data/aeios.db

# Required — Clerk JWT validation (same issuer as the web app)
CLERK_ISSUER=https://your-app.clerk.accounts.dev
# Optional override (defaults to {CLERK_ISSUER}/.well-known/jwks.json)
# CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=

# Optional
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AEIOS_SECRETS_KEY=

# Do NOT set:
# AEIOS_AUTH_DISABLED=1
