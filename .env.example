# AEIOS environment
AEIOS_ENV=development
AEIOS_LOG_LEVEL=INFO

# LLM providers (optional for Phase 0 hello path)
# Used at call time when a model row has no stored key (preferred for local DX).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Encrypt model API keys at rest in SQLite (required to persist keys via API).
# Generate e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
AEIOS_SECRETS_KEY=

# Persistence — SQLite is the local/dev default.
DATABASE_URL=sqlite:///./data/aeios.db
# For Docker Compose Postgres (pip install 'aeios[postgres]'):
# DATABASE_URL=postgresql://aeios:aeios@localhost:5432/aeios
# Schema is create-if-not-exists (MVP; no migration runner).

# Optional vector knowledge index (pip install 'aeios[vector]' + compose qdrant).
# Soft-fails if unreachable; lexical search always works.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aeios_knowledge
QDRANT_ENABLED=1

# Object storage (Phase 2+)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aeios

# FastAPI auth (Clerk JWT) — see docs/AUTH.md
# Escape hatch for CLI / pytest (no Bearer required):
AEIOS_AUTH_DISABLED=1
# To protect /v1/* , unset AEIOS_AUTH_DISABLED and set issuer or JWKS URL:
# CLERK_ISSUER=https://your-app.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=
