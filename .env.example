# AEIOS environment
AEIOS_ENV=development
AEIOS_LOG_LEVEL=INFO

# LLM providers (optional for Phase 0 hello path)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Persistence (optional — defaults to in-memory / local SQLite)
DATABASE_URL=sqlite:///./data/aeios.db
QDRANT_URL=http://localhost:6333

# Object storage (Phase 2+)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aeios
